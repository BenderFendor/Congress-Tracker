#!/usr/bin/env bash
set -euo pipefail

echo "== Self-test =="
echo "Working directory: $(pwd)"
echo

# ---- Backend ----
echo "--- Backend ---"
if [[ -f backend/Cargo.toml ]]; then
  cd backend

  echo "  cargo fmt --check"
  cargo fmt --check

  echo "  cargo clippy --all-targets --all-features"
  cargo clippy --all-targets --all-features

  echo "  cargo check"
  cargo check

  echo "  cargo test"
  cargo test

  cd ..
  echo "  backend checks passed"
else
  echo "  no Cargo.toml; skipping backend"
fi

echo

# ---- Frontend ----
echo "--- Frontend ---"
if [[ -f frontend/package.json ]]; then
  cd frontend

  if ! command -v pnpm >/dev/null 2>&1; then
    echo "  pnpm is required for the frontend verification gate"
    exit 1
  fi

  echo "  pnpm verify"
  pnpm verify

  cd ..
  echo "  frontend checks passed"
else
  echo "  no package.json; skipping frontend"
fi

echo
echo "Self-test completed."
