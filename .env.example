# Congress Accountability Tracker - Environment Variables
# Copy this file to .env and fill in your actual API keys

# ============================================
# Backend Server Configuration
# ============================================
PORT=4020

# ============================================
# CapitolTrades API (Primary Data Source)
# ============================================
# CapitolTrades API doesn't require an API key for public data
# but you can configure custom settings if needed
CAPITOLTRADES_API_BASE_URL=https://www.capitoltrades.com

# ============================================
# Congress.gov API (Legislative Data)
# Required for bills, amendments, votes, member info
# Note: Use the same api.data.gov key for all services
# ============================================
CONGRESS_GOV_API_KEY=your_api_data_gov_key_here
CONGRESS_GOV_API_BASE_URL=https://api.congress.gov

# ============================================
# OpenFEC API (Campaign Finance Data)
# Required for candidate info, committee data, donations
# Note: Use the same api.data.gov key for all services
# ============================================
OPENFEC_API_KEY=your_api_data_gov_key_here
OPENFEC_API_BASE_URL=https://api.open.fec.gov

# ============================================
# USAspending API (Federal Spending Data)
# Optional - for future government spending integration
# ============================================
USASPENDING_API_KEY=your_usaspending_api_key_here
USASPENDING_API_BASE_URL=https://api.usaspending.gov

# ============================================
# Census API (Demographic Data)
# Optional - for future district context integration
# ============================================
CENSUS_API_KEY=your_census_api_key_here
CENSUS_API_BASE_URL=https://api.census.gov

# ============================================
# Senate Lobbying API
# Optional - for lobbying data integration
# Get a key at https://lda.senate.gov/api/register/
# Without a key: 15 req/min. With key: 120 req/min.
# ============================================
SENATE_LDA_API_KEY=your_senate_lobbying_api_key_here
SENATE_LOBBYING_API_KEY=your_senate_lobbying_api_key_here
SENATE_LOBBYING_API_BASE_URL=https://lda.senate.gov/api

# ============================================
# Frontend Configuration (Next.js)
# These are prefixed with NEXT_PUBLIC_ for client-side access
# ============================================
NEXT_PUBLIC_CONGRESS_API_KEY=your_congress_gov_api_key_here
NEXT_PUBLIC_LDA_API_KEY=your_senate_lobbying_api_key_here
NEXT_PUBLIC_CONGRESS_GOV_API_KEY=your_congress_gov_api_key_here

# ============================================
# Development Settings
# ============================================
RUST_LOG=info
